{
  "version": "2.0",
  "track": "v2-foundation",
  "description": "Foundation stress tests (hashing, draw state, time-managed search)",
  "test_categories": {
    "foundation_hash": {
      "description": "Zobrist/hash command contract",
      "required": true,
      "tests": [
        {
          "id": "hash_baseline",
          "name": "Hash Command Baseline",
          "commands": [
            {"cmd": "new"},
            {"cmd": "hash"}
          ],
          "expected_patterns": ["HASH:"],
          "timeout": 3000
        },
        {
          "id": "hash_after_move",
          "name": "Hash Command After Move",
          "commands": [
            {"cmd": "new"},
            {"cmd": "move e2e4"},
            {"cmd": "hash"}
          ],
          "expected_patterns": ["HASH:"],
          "timeout": 3000
        },
        {
          "id": "hash_restore_after_undo",
          "name": "Hash Restores After Undo",
          "commands": [
            {"cmd": "new"},
            {"cmd": "hash"},
            {"cmd": "move e2e4"},
            {"cmd": "undo"},
            {"cmd": "hash"}
          ],
          "expected_patterns": ["HASH:"],
          "output_assertions": [
            {"type": "equal", "first_command": 2, "second_command": 5}
          ],
          "timeout": 3000
        }
      ]
    },
    "foundation_draws": {
      "description": "Draw state command contract",
      "required": true,
      "tests": [
        {
          "id": "draws_command",
          "name": "Draws Command",
          "commands": [
            {"cmd": "new"},
            {"cmd": "draws"}
          ],
          "expected_patterns": ["DRAWS:", "repetition=1", "halfmove=0", "draw=false", "reason=none"],
          "timeout": 3000
        },
        {
          "id": "draws_repetition",
          "name": "Draws Repetition Detection",
          "commands": [
            {"cmd": "new"},
            {"cmd": "move g1f3"},
            {"cmd": "move g8f6"},
            {"cmd": "move f3g1"},
            {"cmd": "move f6g8"},
            {"cmd": "move g1f3"},
            {"cmd": "move g8f6"},
            {"cmd": "move f3g1"},
            {"cmd": "move f6g8"},
            {"cmd": "draws"}
          ],
          "expected_patterns": ["DRAWS:", "repetition=3", "halfmove=8", "draw=true", "reason=repetition"],
          "timeout": 5000
        },
        {
          "id": "draws_fifty_moves",
          "name": "Draws Fifty Move Detection",
          "commands": [
            {"cmd": "fen rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 99 1"},
            {"cmd": "move g1f3"},
            {"cmd": "draws"}
          ],
          "expected_patterns": ["DRAWS:", "halfmove=100", "draw=true", "reason=fifty_moves"],
          "timeout": 3000
        }
      ]
    },
    "foundation_history": {
      "description": "History command contract and rollback behavior",
      "required": true,
      "tests": [
        {
          "id": "history_command",
          "name": "History Command",
          "commands": [
            {"cmd": "new"},
            {"cmd": "history"}
          ],
          "expected_patterns": ["HISTORY:", "count=1", "current="],
          "timeout": 3000
        },
        {
          "id": "history_after_move",
          "name": "History After Move",
          "commands": [
            {"cmd": "new"},
            {"cmd": "move e2e4"},
            {"cmd": "history"}
          ],
          "expected_patterns": ["HISTORY:", "count=2", "current="],
          "timeout": 3000
        },
        {
          "id": "history_after_undo",
          "name": "History After Undo",
          "commands": [
            {"cmd": "new"},
            {"cmd": "move e2e4"},
            {"cmd": "undo"},
            {"cmd": "history"}
          ],
          "expected_patterns": ["HISTORY:", "count=1", "current="],
          "timeout": 3000
        }
      ]
    },
    "foundation_time_management": {
      "description": "Time-managed search command contract",
      "required": true,
      "tests": [
        {
          "id": "go_movetime",
          "name": "Go Movetime",
          "commands": [
            {"cmd": "new"},
            {"cmd": "go movetime 200"}
          ],
          "expected_patterns": ["AI:"],
          "timeout": 8000
        }
      ]
    }
  }
}
