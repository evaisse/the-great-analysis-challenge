{
  "version": "2.0",
  "track": "v2-system",
  "description": "System stress tests (tracing and concurrency safety with fixtures)",
  "test_categories": {
    "system_trace": {
      "description": "Tracing command surface",
      "required": true,
      "tests": [
        {
          "id": "trace_level",
          "name": "Trace Level",
          "commands": [
            {"cmd": "trace on"},
            {"cmd": "trace level debug"},
            {"cmd": "trace report"}
          ],
          "expected_patterns": ["TRACE: enabled=true", "TRACE: level=debug", "level=debug"],
          "timeout": 8000
        },
        {
          "id": "trace_report",
          "name": "Trace Report",
          "commands": [
            {"cmd": "trace on"},
            {"cmd": "new"},
            {"cmd": "ai 1"},
            {"cmd": "trace report"}
          ],
          "expected_patterns": ["TRACE"],
          "timeout": 8000
        },
        {
          "id": "trace_export_file",
          "name": "Trace Export File",
          "commands": [
            {"cmd": "trace on"},
            {"cmd": "new"},
            {"cmd": "ai 1"},
            {"cmd": "trace export {trace_export_path}"}
          ],
          "expected_patterns": ["TRACE: export=", "events=", "bytes="],
          "expected_artifacts": [
            {"placeholder": "trace_export_path", "format": "trace"}
          ],
          "timeout": 12000
        },
        {
          "id": "trace_chrome_file",
          "name": "Trace Chrome File",
          "commands": [
            {"cmd": "trace on"},
            {"cmd": "new"},
            {"cmd": "ai 1"},
            {"cmd": "trace chrome {trace_chrome_path}"}
          ],
          "expected_patterns": ["TRACE: chrome=", "events=", "bytes="],
          "expected_artifacts": [
            {"placeholder": "trace_chrome_path", "format": "chrome"}
          ],
          "timeout": 12000
        },
        {
          "id": "trace_reset",
          "name": "Trace Reset",
          "commands": [
            {"cmd": "trace on"},
            {"cmd": "new"},
            {"cmd": "ai 1"},
            {"cmd": "trace reset"},
            {"cmd": "trace report"}
          ],
          "expected_patterns": ["TRACE: reset", "events=0", "last_ai=none"],
          "timeout": 8000
        }
      ]
    },
    "system_concurrency": {
      "description": "Concurrency contract with fixture-backed command replay",
      "required": true,
      "tests": [
        {
          "id": "concurrency_quick_fixture",
          "name": "Concurrency Quick Fixture",
          "commands": [
            {"fixture_file": "test/fixtures/concurrency/commands_quick.txt"}
          ],
          "expected_patterns": [
            "CONCURRENCY:",
            "\"profile\":\"quick\"",
            "\"deterministic\":true",
            "\"invariant_errors\":0",
            "\"deadlocks\":0",
            "\"timeouts\":0"
          ],
          "timeout": 20000
        },
        {
          "id": "concurrency_full_fixture",
          "name": "Concurrency Full Fixture",
          "commands": [
            {"fixture_file": "test/fixtures/concurrency/commands_full.txt"}
          ],
          "expected_patterns": [
            "CONCURRENCY:",
            "\"profile\":\"full\"",
            "\"deterministic\":true",
            "\"invariant_errors\":0",
            "\"deadlocks\":0",
            "\"timeouts\":0"
          ],
          "timeout": 60000
        }
      ]
    }
  }
}
