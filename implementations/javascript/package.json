{
  "name": "chess-javascript",
  "version": "1.0.0",
  "description": "JavaScript implementation of the polyglot chess engine",
  "type": "module",
  "main": "chess.js",
  "scripts": {
    "start": "bun run chess.js",
    "build": "bun build chess.js --outdir dist --target bun",
    "lint": "bun build chess.js --outdir /tmp/tgac-javascript-lint --target bun",
    "test": "bun test",
    "lint": "bun run analyze",
    "analyze": "bun build chess.js --outdir /tmp/tgac-javascript-check --target bun"
  }
}
